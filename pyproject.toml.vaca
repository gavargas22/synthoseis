[project]
name = "synthoseis"
version = "2.5.1"
description = "Generating seismic data and associated labels to train deep learning networks."
readme = "README.md"
requires-python = ">=3.12"
dependencies = [
    "bruges",
    "matplotlib",
    "noise",
    "numpy",
    "cython",
    "plotly",
    "ruff",
    "scipy",
    "setuptools",
    "tqdm",
    "zarr"
]